{
  "name": "@fiscora/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "npx cross-env PRISMA_GENERATE_SKIP_AUTOINSTALL=true prisma generate --schema ../../prisma/schema.prisma"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/jwt": "^8.0.1",
    "@fastify/multipart": "^10.0.0",
    "@fiscora/labor-engine": "workspace:*",
    "@fiscora/shared": "workspace:*",
    "@fiscora/validators": "workspace:*",
    "@fiscora/xml-engine": "workspace:*",
    "@prisma/client": "5.22.0",
    "argon2": "^0.44.0",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "fast-xml-parser": "^5.8.0",
    "fastify": "^4.26.1",
    "fastify-plugin": "^5.1.0",
    "stripe": "^22.2.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "tsx": "^4.7.1",
    "typescript": "^5.3.3"
  }
}
